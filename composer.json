{
    "name": "laxa/spatie-laravel-permission-plugin",
    "description": "Spatie Laravel Permission integration for Laxa admin panels.",
    "keywords": ["laravel", "laxa", "spatie", "permission", "roles"],
    "homepage": "https://github.com/lareys-org/spatie-laravel-permission-plugin",
    "license": "MIT",
    "authors": [
        {
            "name": "Saiful Islam",
            "email": "saifulapm@gmail.com"
        }
    ],
    "require": {
        "php": "^8.3",
        "laxa/laxa": "^0.3",
        "spatie/laravel-permission": "^6.0"
    },
    "require-dev": {
        "orchestra/testbench": "^11.0",
        "pestphp/pest": "^4.0"
    },
    "autoload": {
        "psr-4": {
            "Laxa\\SpatieLaravelPermissionPlugin\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Laxa\\SpatieLaravelPermissionPlugin\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "vendor/bin/pest --compact"
    },
    "repositories": [
        {
            "type": "composer",
            "url": "https://laxa.app"
        }
    ],
    "extra": {
        "laravel": {
            "providers": [
                "Laxa\\SpatieLaravelPermissionPlugin\\PluginServiceProvider"
            ]
        }
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
